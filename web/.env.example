# Convex deployment URL (must match your Convex dashboard HTTP Actions URL)
NEXT_PUBLIC_API_URL=https://canny-woodpecker-211.convex.site

# Web app origin (for extension login redirect)
NEXT_PUBLIC_WEB_URL=http://localhost:3000

# Clerk authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/register
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/auth/sync
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/auth/sync

# Shared secret for Clerk → Convex user sync (set same value in Convex dashboard env)
CLERK_SYNC_SECRET=

# AI Provider Keys (at least one required)
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# LLM config (optional overrides)
LLM_API_URL=https://openrouter.ai/api/v1/chat/completions
LLM_MODEL=minimax/minimax-m2.5:free

# Allowed CORS origins (comma-separated, used by Convex HTTP)
ALLOWED_ORIGINS=http://localhost:3000,chrome-extension://

# Razorpay billing (amounts in paise, e.g. 99900 = ₹999)
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_WEBHOOK_INTERNAL_SECRET=
RAZORPAY_PLAN_PRO_AMOUNT=99900
RAZORPAY_PLAN_PREMIUM_AMOUNT=249900
